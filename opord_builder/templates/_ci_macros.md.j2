{% endif %}
{% if has_content(ci.time_line) %}{{ ci_time_line(ci) }}
{% endif %}
{% if has_content(ci.earliest_movement_of_forces) %}{{ ci_earliest_movement(ci) }}
{% endif %}
{% if has_content(ci.reconnaissance_and_surveillance_instructions) %}{{ ci_rs_instructions(ci) }}
{% endif %}
{% if has_content(ci.orders_group) %}{{ ci_orders_group(ci) }}
{% endif %}
{% if has_content(ci.rehearsal) %}{{ ci_rehearsal(ci) }}
