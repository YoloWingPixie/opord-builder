<!DOCTYPE html>
{%- set h = opord.header -%}
{%- set class_str = h.classification.value + ('//' + h.classification_caveat if h.classification_caveat else '') -%}
{%- set class_slug = h.classification.css_slug -%}
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>OPORD {{ h.operation_order_number }} — {{ h.operation_name }}</title>
  <style>
    @page {
      size: Letter;
      margin: 0.7in 0.55in 0.65in 0.55in;
      {% if watermark_url %}
      background-image: url("{{ watermark_url }}");
      background-position: center center;
      background-size: 420pt auto;
      background-repeat: no-repeat;
      {% endif %}
      @top-center {
        content: "{{ class_str }}";
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-weight: 700;
        font-size: 7pt;
        letter-spacing: 0.24em;
        color: #ffffff;
        background: linear-gradient(
          to bottom,
          transparent 0%,
          transparent 38%,
          var(--class-color) 38%,
          var(--class-color) 62%,
          transparent 62%,
          transparent 100%
        );
        padding: 0 72pt;
        text-align: center;
        text-transform: uppercase;
        vertical-align: middle;
      }
      @bottom-center {
        content: "{{ class_str }}";
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-weight: 700;
        font-size: 7pt;
        letter-spacing: 0.24em;
        color: #ffffff;
        background: linear-gradient(
          to bottom,
          transparent 0%,
          transparent 38%,
          var(--class-color) 38%,
          var(--class-color) 62%,
          transparent 62%,
          transparent 100%
        );
        padding: 0 72pt;
        text-align: center;
        text-transform: uppercase;
        vertical-align: middle;
      }
      {% if h.page_icon %}
      @top-right {
        content: url("{{ h.page_icon }}");
        width: 28pt;
        height: 28pt;
        padding: 2pt 4pt;
        vertical-align: middle;
      }
      {% endif %}
      @bottom-left {
        content: "OPORD " "{{ h.operation_order_number }}" " / " "{{ h.operation_name }}";
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 6.5pt;
        font-weight: 700;
        letter-spacing: 0.22em;
        color: #45443e;
        padding: 3pt 0;
        white-space: nowrap;
        text-transform: uppercase;
      }
      @bottom-right {
        content: "P " counter(page) " / " counter(pages);
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 6.5pt;
        font-weight: 700;
        letter-spacing: 0.22em;
        color: #45443e;
        padding: 3pt 0;
        white-space: nowrap;
      }
    }
    @page :first {
      background-image: none;
      @top-right { content: none; }
    }
  </style>
  <script>
    (function() {
      try {
        var t = localStorage.getItem("opord-theme");
        if (t === "dark" || t === "light") {
          document.documentElement.setAttribute("data-theme", t);
        }
      } catch (e) {}
    })();
  </script>
</head>
<body class="classification-{{ class_slug }}">

<button class="theme-toggle" type="button" aria-label="Toggle theme" onclick="(function(b){var r=document.documentElement;var c=r.getAttribute('data-theme');var n=c==='dark'?'light':(c==='light'?'dark':(window.matchMedia&&matchMedia('(prefers-color-scheme: dark)').matches?'light':'dark'));r.setAttribute('data-theme',n);try{localStorage.setItem('opord-theme',n);}catch(e){}})(this)">
  <span class="tt-dot"></span>
  <span class="tt-label-dark">Dark</span>
  <span class="tt-label-light">Light</span>
</button>


{#- ================= Macros ================= -#}
{%- macro para_open(num, slug, title, anchor=None, num_class='') -%}
<section class="paragraph para-{{ slug }}" id="{{ anchor or ('para-' ~ slug) }}">
<details open class="section-details">
<summary class="para-header">
    <div class="para-num{% if num_class %} {{ num_class }}{% endif %}">{{ num }}</div>
    <h2 class="para-title">{{ title }}</h2>
    <div class="para-stripe"></div>
    <span class="chevron"></span>
</summary>
{%- endmacro -%}

{%- macro sub(para, letter, j, label, body) -%}
<div class="subpara">
  <div class="subpara-label">
    <span class="subpara-num">{{ para }}.{{ letter }}.({{ j }})</span>
    <span class="subpara-title">{{ label }}</span>
  </div>
  <div class="subpara-body">{{ body }}</div>
</div>
{%- endmacro -%}

{%- macro unit_card(unit, depth=0) -%}
<div class="unit-card{% if depth == 0 %} unit-root{% endif %}" style="--d:{{ depth }}">
  <div class="unit-header">
    <div class="unit-name">{{ unit.name }}</div>
    {% if unit.callsign %}<div class="unit-callsign">{{ unit.callsign }}</div>{% endif %}
  </div>
  <div class="unit-meta">
    {% if unit.relationship %}<span class="chip chip-rel">{{ unit.relationship }}</span>{% endif %}
    {% if unit.role %}<span class="chip chip-role">{{ unit.role }}</span>{% endif %}
    {% if unit.commander %}<span class="unit-commander">{{ unit.commander }}</span>{% endif %}
  </div>
  {% if unit.subordinate_units %}
  <div class="unit-children">
    {% for child in unit.subordinate_units %}{{ unit_card(child, depth + 1) }}{% endfor %}
  </div>
  {% endif %}
</div>
{%- endmacro -%}

{#- ================= Cover block ================= -#}
<section class="cover">
  <div class="cover-hero">
    <div class="cover-eyebrow">
      <span class="cover-eyebrow-tag">OPERATION ORDER</span>
      <span class="cover-eyebrow-num">{{ h.operation_order_number }}</span>
    </div>
    <h1 class="cover-title">{{ h.operation_name }}</h1>
    {% if h.author %}
    <div class="cover-author">
      <span class="cover-author-label">Drafted by</span>
      <span class="cover-author-name">{{ h.author }}</span>
    </div>
    {% endif %}
    <div class="cover-accent" data-serial="{{ generated_at }}"></div>
  </div>
  {% if h.logo %}
  <div class="cover-logo-plate">
    <img class="cover-logo" src="{{ h.logo }}" alt="Unit crest">
  </div>
  {% endif %}

  <div class="cover-meta">
    <div class="meta-card">
      <div class="meta-label">Issuing Headquarters</div>
      <div class="meta-value">{{ h.issuing_headquarters }}</div>
    </div>
    <div class="meta-card">
      <div class="meta-label">Place of Issue</div>
      <div class="meta-value">{{ h.place_of_issue }}</div>
    </div>
    <div class="meta-card mono">
      <div class="meta-label">Date-Time Group</div>
      <div class="meta-value">{{ h.dtg }}</div>
    </div>
    <div class="meta-card mono">
      <div class="meta-label">Time Zone</div>
      <div class="meta-value">{{ h.time_zone }}</div>
    </div>
    {% if h.copy_number %}
    <div class="meta-card mono">
      <div class="meta-label">Copy</div>
      <div class="meta-value">{{ h.copy_number }}{% if h.number_of_copies %} <span class="of">of</span> {{ h.number_of_copies }}{% endif %}</div>
    </div>
    {% endif %}
    {% if h.message_reference_number %}
    <div class="meta-card mono">
      <div class="meta-label">Message Ref. No.</div>
      <div class="meta-value">{{ h.message_reference_number }}</div>
    </div>
    {% endif %}
  </div>
</section>

{% if has_content(h.references) %}
<section class="card card-references">
  <div class="card-accent accent-refs"></div>
  <div class="card-head">
    <span class="card-eyebrow">(U)</span>
    <h2 class="card-title">References</h2>
  </div>
  <ol class="ref-list">
    {% for ref in h.references %}
    <li>
      <span class="ref-letter">{{ letter_for(loop.index) }}.</span>
      <span class="ref-cite">{{ ref.citation }}</span>
      {% if ref.description %}<span class="ref-desc">— {{ ref.description }}</span>{% endif %}
    </li>
    {% endfor %}
  </ol>
</section>
{% endif %}

{% if has_content(h.task_organization) %}
<section class="card card-taskorg">
  <div class="card-accent accent-taskorg"></div>
  <div class="card-head">
    <span class="card-eyebrow">(U)</span>
    <h2 class="card-title">Task Organization</h2>
    <span class="card-annex-ref">Annex A</span>
  </div>
  <div class="taskorg-tree">{{ unit_card(h.task_organization) }}</div>
</section>
{% elif h.task_organization_note %}
<section class="card card-taskorg-note">
  <div class="card-accent accent-taskorg"></div>
  <div class="card-head">
    <span class="card-eyebrow">(U)</span>
    <h2 class="card-title">Task Organization</h2>
  </div>
  <p class="card-note">{{ h.task_organization_note }}</p>
</section>
{% endif %}

{#- =================== TABLE OF CONTENTS =================== -#}
<nav class="doc-toc" aria-label="Contents">
  <div class="doc-toc-title">Contents</div>
  <div class="doc-toc-paragraphs">
    {% if has_content(opord.situation) %}<a href="#para-1" class="toc-para-link"><span class="toc-num">1</span>Situation</a>{% endif %}
    <a href="#para-2" class="toc-para-link"><span class="toc-num">2</span>Mission</a>
    {% if has_content(opord.execution) %}<a href="#para-3" class="toc-para-link"><span class="toc-num">3</span>Execution</a>{% endif %}
    {% if has_content(opord.sustainment) %}<a href="#para-4" class="toc-para-link"><span class="toc-num">4</span>Sustainment</a>{% endif %}
    {% if has_content(opord.command_and_signal) %}<a href="#para-5" class="toc-para-link"><span class="toc-num">5</span>Command and Signal</a>{% endif %}
    <a href="#annexes" class="toc-para-link"><span class="toc-num">A</span>Annexes</a>
    {% if has_content(opord.authentication) %}<a href="#authentication" class="toc-para-link"><span class="toc-num">§</span>Authentication</a>{% endif %}
  </div>
  <div class="doc-toc-annex-label">Annexes</div>
  <div class="doc-toc-annex-grid">
    {% for a in annex_directory %}
    <a href="#annex-{{ a.letter }}" class="toc-annex-tile toc-annex-{{ a.status.css_slug }}">
      <span class="toc-annex-letter">{{ a.letter }}</span>
      <span class="toc-annex-title">{{ a.title }}</span>
    </a>
    {% endfor %}
  </div>
</nav>

{#- =================== PARAGRAPH 1 — SITUATION =================== -#}
{% set s = opord.situation %}
{% if has_content(s) %}
{{ para_open(1, "1", "Situation") }}

  {% set ns = namespace(i=0) %}
  {% if has_content(s.area_of_interest) %}
    {% set ns.i = ns.i + 1 %}
    <div class="card subpara-card">
      <div class="card-accent accent-1"></div>
      <div class="card-head"><span class="num mono">1.{{ letter_for(ns.i) }}</span><h3 class="card-title">Area of Interest</h3></div>
      <p>{{ s.area_of_interest }}</p>
    </div>
  {% endif %}

  {% if has_content(s.area_of_operations) %}
    {% set ns.i = ns.i + 1 %}
    {% set ao_letter = letter_for(ns.i) %}
    <div class="card subpara-card">
      <div class="card-accent accent-1"></div>
      <div class="card-head"><span class="num mono">1.{{ ao_letter }}</span><h3 class="card-title">Area of Operations</h3></div>
      {% if has_content(s.area_of_operations.description) %}<p>{{ s.area_of_operations.description }}</p>{% endif %}

      {% set subns = namespace(j=0) %}
      {% if has_content(s.area_of_operations.terrain) %}
        {% set subns.j = subns.j + 1 %}
        {% set t = s.area_of_operations.terrain %}
        <div class="nested">
          <div class="nested-head"><span class="mono">1.{{ ao_letter }}.({{ subns.j }})</span><h4>Terrain — OAKOC</h4></div>
          <div class="oakoc-grid">
            {% if has_content(t.observation_and_fields_of_fire) %}<div class="oakoc-cell"><span class="oakoc-key">O</span><div><strong>Observation &amp; Fields of Fire.</strong> {{ t.observation_and_fields_of_fire }}</div></div>{% endif %}
            {% if has_content(t.avenues_of_approach) %}<div class="oakoc-cell"><span class="oakoc-key">A</span><div><strong>Avenues of Approach.</strong> {{ t.avenues_of_approach }}</div></div>{% endif %}
            {% if has_content(t.key_terrain) %}<div class="oakoc-cell"><span class="oakoc-key">K</span><div><strong>Key Terrain.</strong> {{ t.key_terrain }}</div></div>{% endif %}
            {% if has_content(t.obstacles) %}<div class="oakoc-cell"><span class="oakoc-key">O</span><div><strong>Obstacles.</strong> {{ t.obstacles }}</div></div>{% endif %}
            {% if has_content(t.cover_and_concealment) %}<div class="oakoc-cell"><span class="oakoc-key">C</span><div><strong>Cover &amp; Concealment.</strong> {{ t.cover_and_concealment }}</div></div>{% endif %}
          </div>
        </div>
      {% endif %}

      {% if has_content(s.area_of_operations.weather) %}
        {% set subns.j = subns.j + 1 %}
        {% set w = s.area_of_operations.weather %}
        <div class="nested">
          <div class="nested-head"><span class="mono">1.{{ ao_letter }}.({{ subns.j }})</span><h4>Weather</h4></div>
          <div class="weather-rows">
            {% if has_content(w.visibility) %}<div class="wx-row"><span class="wx-row-k">Visibility</span><span class="wx-row-v">{{ w.visibility }}</span></div>{% endif %}
            {% if has_content(w.winds) %}<div class="wx-row"><span class="wx-row-k">Winds</span><span class="wx-row-v">{{ w.winds }}</span></div>{% endif %}
            {% if has_content(w.precipitation) %}<div class="wx-row"><span class="wx-row-k">Precipitation</span><span class="wx-row-v">{{ w.precipitation }}</span></div>{% endif %}
            {% if has_content(w.cloud_cover) %}<div class="wx-row"><span class="wx-row-k">Cloud Cover</span><span class="wx-row-v">{{ w.cloud_cover }}</span></div>{% endif %}
            {% if has_content(w.temperature_and_humidity) %}<div class="wx-row"><span class="wx-row-k">Temp / RH</span><span class="wx-row-v">{{ w.temperature_and_humidity }}</span></div>{% endif %}
            {% if has_content(w.light_data) %}<div class="wx-row"><span class="wx-row-k">Light Data</span><span class="wx-row-v">{{ w.light_data }}</span></div>{% endif %}
          </div>

          {% if has_content(w.light_data_structured) %}
          {% set ld = w.light_data_structured %}
          <div class="wx-struct">
            <div class="wx-struct-label">Astronomical Data{% if ld.date %} · {{ ld.date }}{% endif %}</div>
            <div class="wx-struct-grid">
              {% if ld.bmnt %}<div class="wx-item"><span class="wx-k">BMNT</span><span class="wx-v mono">{{ ld.bmnt }}</span></div>{% endif %}
              {% if ld.sunrise %}<div class="wx-item"><span class="wx-k">Sunrise</span><span class="wx-v mono">{{ ld.sunrise }}</span></div>{% endif %}
              {% if ld.sunset %}<div class="wx-item"><span class="wx-k">Sunset</span><span class="wx-v mono">{{ ld.sunset }}</span></div>{% endif %}
              {% if ld.eent %}<div class="wx-item"><span class="wx-k">EENT</span><span class="wx-v mono">{{ ld.eent }}</span></div>{% endif %}
              {% if ld.moonrise %}<div class="wx-item"><span class="wx-k">Moonrise</span><span class="wx-v mono">{{ ld.moonrise }}</span></div>{% endif %}
              {% if ld.moonset %}<div class="wx-item"><span class="wx-k">Moonset</span><span class="wx-v mono">{{ ld.moonset }}</span></div>{% endif %}
              {% if ld.moon_phase %}<div class="wx-item"><span class="wx-k">Phase</span><span class="wx-v">{{ ld.moon_phase }}</span></div>{% endif %}
              {% if ld.percent_illumination is not none %}<div class="wx-item"><span class="wx-k">Illum</span><span class="wx-v mono">{{ ld.percent_illumination }}%</span></div>{% endif %}
            </div>
          </div>
          {% endif %}

          {% if has_content(w.climate_baseline) %}
          <div class="wx-block">
            <div class="wx-block-label">Climate Baseline</div>
            <div class="wx-block-body">{{ w.climate_baseline }}</div>
          </div>
          {% endif %}

          {% if has_content(w.forecast_by_period) %}
          <div class="wx-block">
            <div class="wx-block-label">Operation-Period Forecast</div>
            <div class="wx-periods">
              {% for f in w.forecast_by_period %}
              <div class="wx-period">
                <div class="wx-period-head">
                  <span class="wx-period-phase">{{ f.phase_or_day }}</span>
                  {% if f.period_start or f.period_end %}
                  <span class="wx-period-window mono">
                    {%- if f.period_start %}{{ f.period_start }}{% endif -%}
                    {%- if f.period_end %} → {{ f.period_end }}{% endif -%}
                  </span>
                  {% endif %}
                </div>
                <div class="wx-period-grid">
                  {% if f.visibility %}<div class="wx-period-cell"><span class="wx-period-k">Visibility</span><span class="wx-period-v">{{ f.visibility }}</span></div>{% endif %}
                  {% if f.winds %}<div class="wx-period-cell"><span class="wx-period-k">Winds</span><span class="wx-period-v">{{ f.winds }}</span></div>{% endif %}
                  {% if f.precipitation %}<div class="wx-period-cell"><span class="wx-period-k">Precip</span><span class="wx-period-v">{{ f.precipitation }}</span></div>{% endif %}
                  {% if f.cloud_cover %}<div class="wx-period-cell"><span class="wx-period-k">Clouds</span><span class="wx-period-v">{{ f.cloud_cover }}</span></div>{% endif %}
                  {% if f.temperature_and_humidity %}<div class="wx-period-cell"><span class="wx-period-k">Temp / RH</span><span class="wx-period-v">{{ f.temperature_and_humidity }}</span></div>{% endif %}
                </div>
                {% if f.effects_on_operations %}
                <div class="wx-period-effect">
                  <span class="wx-period-k">Effects on Ops</span>
                  <span class="wx-period-v">{{ f.effects_on_operations }}</span>
                </div>
                {% endif %}
              </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {% if has_content(w.effects_on_operations) %}
          <div class="wx-block wx-effects">
            <div class="wx-block-label">Net Effects on Operations</div>
            <div class="wx-block-body">{{ w.effects_on_operations }}</div>
          </div>
          {% endif %}

          {% if has_content(w.forecast_confidence) or has_content(w.swo_product_reference) %}
          <div class="wx-meta">
            {% if has_content(w.forecast_confidence) %}<span class="wx-meta-item"><strong>Forecast confidence:</strong> {{ w.forecast_confidence }}</span>{% endif %}
            {% if has_content(w.swo_product_reference) %}<span class="wx-meta-item"><strong>SWO product:</strong> {{ w.swo_product_reference }}</span>{% endif %}
          </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% endif %}

  {% if has_content(s.enemy_forces) %}
    {% set ns.i = ns.i + 1 %}
    {% set e_letter = letter_for(ns.i) %}
    {% set e = s.enemy_forces %}
    <div class="card subpara-card">
      <div class="card-accent accent-1"></div>
      <div class="card-head"><span class="num mono">1.{{ e_letter }}</span><h3 class="card-title">Enemy Forces</h3></div>
      {% set ens = namespace(j=0) %}
      {% set e_fields = [
        ('composition_disposition_strength', 'Composition, Disposition, and Strength'),
        ('recent_activities', 'Recent Activities'),
        ('capabilities', 'Capabilities'),
        ('most_likely_coa', 'Most Likely Course of Action'),
        ('most_dangerous_coa', 'Most Dangerous Course of Action'),
      ] %}
      {% for attr, label in e_fields %}
        {% set val = e[attr] %}
        {% if has_content(val) %}
          {% set ens.j = ens.j + 1 %}
          {{ sub('1', e_letter, ens.j, label, val) }}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {% if has_content(s.friendly_forces) %}
    {% set ns.i = ns.i + 1 %}
    {% set f_letter = letter_for(ns.i) %}
    {% set f = s.friendly_forces %}
    <div class="card subpara-card">
      <div class="card-accent accent-1"></div>
      <div class="card-head"><span class="num mono">1.{{ f_letter }}</span><h3 class="card-title">Friendly Forces</h3></div>
      {% if has_content(f.higher_headquarters) %}
        {% set hh = f.higher_headquarters %}
        <div class="higher-hq-block">
          {% if hh.two_up_mission or hh.two_up_intent or hh.two_up_designation %}
          <div class="hq-tier">
            <div class="hq-tag">Two Levels Up{% if hh.two_up_designation %} · {{ hh.two_up_designation }}{% endif %}</div>
            {% if hh.two_up_mission %}<div class="hq-row"><span class="hq-label">Mission</span><span>{{ hh.two_up_mission }}</span></div>{% endif %}
            {% if hh.two_up_intent %}<div class="hq-row"><span class="hq-label">Intent</span><span>{{ hh.two_up_intent }}</span></div>{% endif %}
          </div>
          {% endif %}
          {% if hh.one_up_mission or hh.one_up_intent or hh.one_up_designation %}
          <div class="hq-tier">
            <div class="hq-tag">One Level Up{% if hh.one_up_designation %} · {{ hh.one_up_designation }}{% endif %}</div>
            {% if hh.one_up_mission %}<div class="hq-row"><span class="hq-label">Mission</span><span>{{ hh.one_up_mission }}</span></div>{% endif %}
            {% if hh.one_up_intent %}<div class="hq-row"><span class="hq-label">Intent</span><span>{{ hh.one_up_intent }}</span></div>{% endif %}
          </div>
          {% endif %}
        </div>
      {% endif %}
      {% if has_content(f.adjacent_units) %}<div class="inline-kv"><span class="inline-label">Adjacent Units.</span> {{ f.adjacent_units }}</div>{% endif %}
      {% if has_content(f.other_units) %}<div class="inline-kv"><span class="inline-label">Other Units.</span> {{ f.other_units }}</div>{% endif %}
    </div>
  {% endif %}

  {% if has_content(s.interagency_intergovernmental_ngo) %}
    {% set ns.i = ns.i + 1 %}
    <div class="card subpara-card">
      <div class="card-accent accent-1"></div>
      <div class="card-head"><span class="num mono">1.{{ letter_for(ns.i) }}</span><h3 class="card-title">Interagency, Intergovernmental, and Nongovernmental Organizations</h3></div>
      <p>{{ s.interagency_intergovernmental_ngo }}</p>
    </div>
  {% endif %}

  {% if has_content(s.civil_considerations) %}
    {% set ns.i = ns.i + 1 %}
    {% set cc = s.civil_considerations %}
    <div class="card subpara-card">
      <div class="card-accent accent-1"></div>
      <div class="card-head"><span class="num mono">1.{{ letter_for(ns.i) }}</span><h3 class="card-title">Civil Considerations — ASCOPE</h3></div>
      <div class="ascope-grid">
        {% if has_content(cc.areas) %}<div class="ascope-cell"><span class="ascope-key">A</span><div><strong>Areas.</strong> {{ cc.areas }}</div></div>{% endif %}
        {% if has_content(cc.structures) %}<div class="ascope-cell"><span class="ascope-key">S</span><div><strong>Structures.</strong> {{ cc.structures }}</div></div>{% endif %}
        {% if has_content(cc.capabilities) %}<div class="ascope-cell"><span class="ascope-key">C</span><div><strong>Capabilities.</strong> {{ cc.capabilities }}</div></div>{% endif %}
