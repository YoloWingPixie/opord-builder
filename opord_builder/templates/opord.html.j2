    <div class="annex-section">
      <div class="annex-section-label">Distribution List</div>
      <ul class="distribution-list">
        {% for rec in a.distribution_list %}<li>{{ rec }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if has_content(a.body) %}
    <div class="annex-section">
      {% for para in a.body | paragraphs %}<p>{{ para }}</p>{% endfor %}
    </div>
    {% endif %}

    {% if a.typed_body is not none %}
    <div class="annex-section">
      <div class="annex-section-label">Structured Content</div>
      {{ render_typed_body_html(a.typed_body) | safe }}
    </div>
    {% endif %}

    {% if has_content(a.call_sign_groups) %}
    <div class="annex-section">
      <div class="annex-section-label">Call Sign Assignments</div>
      {% for group in a.call_sign_groups %}
      <div class="callsign-group">
        <div class="callsign-group-heading">{{ group.category }}</div>
        <table class="callsign-table">
          <tbody>
            {% for entry in group.entries %}
            <tr>
              <td class="cs-unit">{{ entry.unit }}</td>
              <td class="cs-dash">—</td>
              <td class="cs-callsign mono">{{ entry.callsign }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if has_content(a.appendices) %}
    <div class="appendix-list">
      {% for ap in a.appendices %}
      <div class="appendix-item" id="annex-{{ a.letter }}-app-{{ ap.number }}">
        <details open class="appendix-details">
        <summary class="app-head app-head-summary">
          <span class="mono">App. {{ ap.number }} ({{ a.letter }})</span><strong>{{ ap.title }}</strong>
          <span class="chevron"></span>
        </summary>
        {% if has_content(ap.distribution_list) %}
        <div class="app-subsection">
          <div class="annex-section-label small">Distribution List</div>
          <ul class="distribution-list">
            {% for rec in ap.distribution_list %}<li>{{ rec }}</li>{% endfor %}
          </ul>
        </div>
        {% endif %}
        {% if has_content(ap.body) %}
          {% for para in ap.body | paragraphs %}<p>{{ para }}</p>{% endfor %}
        {% endif %}
        {% if has_content(ap.frequency_tables) %}
          {% for ft in ap.frequency_tables %}
          <div class="freq-table">
            <div class="freq-table-title">
              {{ ft.title }}{% if ft.sub_title %} <span class="freq-sub">· {{ ft.sub_title }}</span>{% endif %}
            </div>
            <table class="freq-channel-table">
              <thead>
                <tr>
                  <th class="freq-th-name">Name</th>
                  <th class="freq-th-ch">Ch</th>
                  <th class="freq-th-freq">Frequency</th>
                  <th class="freq-th-purpose">Purpose</th>
                </tr>
              </thead>
              <tbody>
                {% for ch in ft.channels %}
                <tr>
                  <td class="mono freq-name">{{ ch.name }}</td>
                  <td class="mono freq-ch">{{ ch.channel }}</td>
                  <td class="mono freq-freq">{{ ch.frequency }}</td>
                  <td class="freq-purpose">{{ ch.purpose }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          {% endfor %}
        {% endif %}
        </details>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endfor %}
</details>
</section>

{#- =================== AUTHENTICATION =================== -#}
{% set auth = opord.authentication %}
{% if has_content(auth) %}
<section class="auth-block" id="authentication">
  {% if auth.acknowledge %}<div class="auth-line auth-ack">ACKNOWLEDGE.</div>{% endif %}
  {% if auth.commander_last_name or auth.commander_rank %}
  <div class="auth-name">
    <span class="auth-surname">{{ (auth.commander_last_name or '') | upper }}</span>{% if auth.commander_rank %}<span class="auth-rank">, {{ auth.commander_rank }}</span>{% endif %}
  </div>
  {% endif %}
  {% if auth.authenticating_officer_name or auth.authenticating_officer_position %}
  <div class="auth-official">
    <div class="auth-official-tag">OFFICIAL</div>
    {% if auth.authenticating_officer_name %}<div>{{ auth.authenticating_officer_name }}</div>{% endif %}
    {% if auth.authenticating_officer_position %}<div class="auth-pos">{{ auth.authenticating_officer_position }}</div>{% endif %}
  </div>
  {% endif %}
  {% if has_content(auth.distribution) %}
  <div class="auth-distribution">
    <div class="auth-distro-tag">DISTRIBUTION</div>
    <div>{{ auth.distribution }}</div>
  </div>
  {% endif %}
</section>
{% endif %}

</body>
</html>
